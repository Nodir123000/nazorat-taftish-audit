generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model audit_log {
  log_id     Int       @id @default(autoincrement())
  user_id    Int?
  action     String    @db.VarChar(255)
  table_name String?   @db.VarChar(100)
  record_id  Int?
  old_value  String?
  new_value  String?
  ip_address String?   @db.VarChar(50)
  created_at DateTime? @default(now())
  users      users?    @relation(fields: [user_id], references: [user_id])
}

model audit_reports {
  id               Int        @id @default(autoincrement())
  audit_id         Int
  report_number    String?    @db.VarChar(50)
  report_date      DateTime   @db.Date
  summary          String?
  status           String     @db.VarChar(50)
  findings_count   Int?       @default(0)
  violations_count Int?       @default(0)
  total_amount     Decimal?   @db.Decimal(18, 2)
  created_at       DateTime?  @default(now())
  updated_at       DateTime?  @default(now())
  audits           audits     @relation(fields: [audit_id], references: [id])
  findings         findings[]
}

model audits {
  id                 Int                  @id @default(autoincrement())
  monthly_plan_id    Int?
  order_id           Int?
  audit_number       String               @db.VarChar(50)
  audit_type         String               @db.VarChar(100)
  unit_id            Int
  unit_name          String?              @db.VarChar(255)
  start_date         DateTime             @db.Date
  end_date           DateTime             @db.Date
  status             String               @default("planned") @db.VarChar(50)
  lead_auditor_id    Int?
  team_size          Int?                 @default(1)
  created_at         DateTime?            @default(now())
  audit_reports      audit_reports[]
  users              users?               @relation(fields: [lead_auditor_id], references: [user_id])
  monthly_plans      monthly_plans?       @relation(fields: [monthly_plan_id], references: [id])
  orders             orders?              @relation(fields: [order_id], references: [id])
  ref_units          ref_units            @relation(fields: [unit_id], references: [unit_id])
  commission_members commission_members[]
  violations         violations[]
}

model briefings {
  id               Int           @id @default(autoincrement())
  plan_id          Int
  instructor_id    Int
  instruction_date DateTime      @db.Date
  safety_measures  String?
  status           String        @default("conducted")
  created_at       DateTime      @default(now())
  updated_at       DateTime
  users            users         @relation(fields: [instructor_id], references: [user_id])
  rev_plan_year    rev_plan_year @relation(fields: [plan_id], references: [plan_id])
}

model commission_members {
  id             Int        @id @default(autoincrement())
  audit_id       Int?
  order_id       Int
  user_id        Int?
  role           String     @db.VarChar(50)
  is_responsible Boolean?   @default(false)
  assigned_from  DateTime?  @db.Date
  assigned_to    DateTime?  @db.Date
  personnel_id   Int?
  created_at     DateTime?  @default(now())
  audits         audits?    @relation(fields: [audit_id], references: [id])
  orders         orders     @relation(fields: [order_id], references: [id])
  personnel      personnel? @relation(fields: [personnel_id], references: [id])
  users          users?     @relation(fields: [user_id], references: [user_id])
}

model decisions {
  id                   Int        @id @default(autoincrement())
  violation_id         Int
  decision_number      String     @db.VarChar(50)
  decision_type        String     @db.VarChar(100)
  description          String
  responsible_executor String?    @db.VarChar(255)
  deadline             DateTime?  @db.Date
  status               String     @db.VarChar(50)
  issued_date          DateTime?  @db.Date
  created_at           DateTime?  @default(now())
  violations           violations @relation(fields: [violation_id], references: [id])
}

model doc_view_logs {
  id            Int           @id @default(autoincrement())
  user_id       Int
  doc_id        String
  doc_type      String
  viewed_at     DateTime      @default(now())
  created_at    DateTime?     @default(now())
  help_articles help_articles @relation(fields: [doc_id], references: [id])
  users         users         @relation(fields: [user_id], references: [user_id])
}


model documents {
  id           Int       @id @default(autoincrement())
  file_name    String    @db.VarChar(255)
  file_type    String    @db.VarChar(100)
  storage_path String    @db.VarChar(500)
  file_size    Int?
  description  String?
  uploaded_at  DateTime? @default(now())
  entity_type  String?   @db.VarChar(50)
  entity_id    Int?
  created_at   DateTime? @default(now())
}

model financial_audits {
  id                            Int                    @id @default(autoincrement())
  unit                          String                 @db.VarChar(255)
  unit_subtitle                 String?                @db.VarChar(255)
  control_body                  String?                @db.VarChar(255)
  inspection_direction          String?                @db.VarChar(255)
  inspection_direction_subtitle String?                @db.VarChar(255)
  inspection_type               String?                @db.VarChar(100)
  date                          DateTime?              @db.Date
  cashier                       String?                @db.VarChar(255)
  cashier_role                  String?                @db.VarChar(255)
  balance                       Decimal?               @default(0) @db.Decimal(18, 2)
  status                        String                 @default("draft") @db.VarChar(50)
  inspector_id                  Int?
  inspector_name                String?                @db.VarChar(255)
  prescription_id               Int?
  created_at                    DateTime?              @default(now())
  updated_at                    DateTime?              @default(now())
  personnel                     personnel?             @relation(fields: [inspector_id], references: [id])
  financial_violations          financial_violations[]
}

model financial_repayments {
  id                   Int                  @id @default(autoincrement())
  violation_id         Int
  dj_article           String               @db.VarChar(100)
  document_name        String               @db.VarChar(255)
  document_number      String               @db.VarChar(100)
  document_date        DateTime             @db.Date
  repaid_amount        Decimal              @db.Decimal(18, 2)
  remainder_after      Decimal              @db.Decimal(18, 2)
  created_at           DateTime             @default(now())
  updated_at           DateTime
  financial_violations financial_violations @relation(fields: [violation_id], references: [id], onDelete: Cascade)
}

model financial_violations {
  id                   Int                    @id @default(autoincrement())
  audit_id             Int
  kind                 String?                @db.VarChar(100)
  type                 String?                @db.VarChar(100)
  source               String?                @db.VarChar(100)
  amount               Decimal?               @default(0) @db.Decimal(18, 2)
  recovered            Decimal?               @default(0) @db.Decimal(18, 2)
  count                Int?                   @default(0)
  responsible          String?                @db.VarChar(255)
  created_at           DateTime?              @default(now())
  updated_at           DateTime?              @default(now())
  recovered_count      Int?                   @default(0)
  financial_repayments financial_repayments[]
  financial_audits     financial_audits       @relation(fields: [audit_id], references: [id], onDelete: Cascade)
}

model findings {
  id                  Int           @id @default(autoincrement())
  report_id           Int
  description         String
  severity            String        @db.VarChar(50)
  responsible_unit_id Int?
  due_date            DateTime?     @db.Date
  status              String        @default("open") @db.VarChar(50)
  closure_date        DateTime?     @db.Date
  created_at          DateTime?     @default(now())
  audit_reports       audit_reports @relation(fields: [report_id], references: [id])
  ref_units           ref_units?    @relation(fields: [responsible_unit_id], references: [unit_id])
}

model help_articles {
  id            String          @id
  title         String
  category      String
  content       String
  keywords      String[]
  video_url     String?
  author_id     Int?
  status        String          @default("published")
  created_at    DateTime        @default(now())
  updated_at    DateTime
  doc_view_logs doc_view_logs[]
}

model monthly_plans {
  id                Int             @id @default(autoincrement())
  quarterly_plan_id Int
  month             Int
  year              Int
  status            String          @default("draft") @db.VarChar(50)
  planned_audits    Int             @default(0)
  created_at        DateTime?       @default(now())
  audits            audits[]
  quarterly_plans   quarterly_plans @relation(fields: [quarterly_plan_id], references: [id])
}

model orders {
  id                 Int                  @id @default(autoincrement())
  order_number       String               @unique @db.VarChar(50)
  order_date         DateTime             @db.Date
  issuer_id          Int
  plan_id            Int?
  unit_id            Int?
  order_type         String?              @db.VarChar(50)
  status             String               @default("issued") @db.VarChar(50)
  created_at         DateTime?            @default(now())
  updated_at         DateTime?            @default(now())
  audits             audits[]
  commission_members commission_members[]
  users              users                @relation(fields: [issuer_id], references: [user_id])
  rev_plan_year      rev_plan_year?       @relation(fields: [plan_id], references: [plan_id])
  ref_units          ref_units?           @relation(fields: [unit_id], references: [unit_id])
}

model personnel {
  id                      Int                       @id @default(autoincrement())
  physical_person_id      Int
  service_number          String?                   @unique @db.VarChar(50)
  pnr                     String?                   @unique @db.VarChar(50)
  rank_id                 Int?
  unit_id                 Int?
  position_id             Int?
  vus_id                  Int?
  category_id             Int?
  status                  String?                   @default("active") @db.VarChar(50)
  service_start_date      DateTime?                 @db.Date
  service_end_date        DateTime?                 @db.Date
  clearance_level         String?                   @db.VarChar(50)
  emergency_contact       String?                   @db.VarChar(255)
  emergency_phone         String?                   @db.VarChar(50)
  full_name               String?
  created_at              DateTime?                 @default(now())
  updated_at              DateTime?                 @default(now())
  commission_members      commission_members[]
  financial_audits        financial_audits[]
  internal_investigations internal_investigations[]
  ref_physical_persons    ref_physical_persons      @relation(fields: [physical_person_id], references: [id])
  ref_positions           ref_positions?            @relation(fields: [position_id], references: [id])
  ref_ranks               ref_ranks?                @relation(fields: [rank_id], references: [rank_id])
  ref_units               ref_units?                @relation(fields: [unit_id], references: [unit_id])
  ref_vus_list            ref_vus_list?             @relation(fields: [vus_id], references: [id])
  contracts               personnel_contracts[]
  service_history         personnel_service_history[]
}

model plan_change_log {
  id            Int           @id @default(autoincrement())
  plan_id       Int
  change_type   String        @db.VarChar(50)
  description   String
  changed_at    DateTime?     @default(now())
  created_at    DateTime?     @default(now())
  rev_plan_year rev_plan_year @relation(fields: [plan_id], references: [plan_id])
}

model prescriptions {
  id               Int           @id @default(autoincrement())
  plan_id          Int
  prescription_num String        @unique @db.VarChar(50)
  date             DateTime      @db.Date
  issuer_id        Int
  status           String        @default("issued")
  created_at       DateTime      @default(now())
  updated_at       DateTime
  users            users         @relation(fields: [issuer_id], references: [user_id])
  rev_plan_year    rev_plan_year @relation(fields: [plan_id], references: [plan_id])
}

model quarterly_plans {
  id             Int             @id @default(autoincrement())
  annual_plan_id Int
  quarter        Int
  year           Int
  status         String          @default("draft") @db.VarChar(50)
  planned_audits Int             @default(0)
  created_at     DateTime?       @default(now())
  monthly_plans  monthly_plans[]
  rev_plan_year  rev_plan_year   @relation(fields: [annual_plan_id], references: [plan_id])
}

model ref_areas {
  id                     Int                      @id @default(autoincrement())
  region_id              Int
  code                   String?                  @unique @db.VarChar(50)
  name                   Json
  type                   String?                  @db.VarChar(50)
  status                 String?                  @default("active") @db.VarChar(20)
  created_at             DateTime?                @default(now())
  ref_regions            ref_regions              @relation(fields: [region_id], references: [id])
  ref_military_districts ref_military_districts[]
  ref_physical_persons   ref_physical_persons[]
  ref_units              ref_units[]
}

model ref_audit_objects {
  id         Int       @id @default(autoincrement())
  code       String?   @unique @db.VarChar(50)
  name       Json
  status     String?   @default("active") @db.VarChar(20)
  created_at DateTime? @default(now())
}

model ref_award_penalties {
  id         Int       @id @default(autoincrement())
  code       String?   @unique @db.VarChar(50)
  name       Json
  status     String?   @default("active") @db.VarChar(20)
  created_at DateTime? @default(now())
}

model ref_budget_articles {
  article_id        Int       @id @default(autoincrement())
  code              String    @unique @db.VarChar(50)
  name              Json
  parent_article_id Int?
  description       String?
  is_active         Boolean?  @default(true)
  created_at        DateTime? @default(now())
}

model ref_classifiers {
  id         Int       @id @default(autoincrement())
  type       String    @db.VarChar(100)
  code       String?   @db.VarChar(50)
  name       Json
  parent_id  Int?
  sort_order Int?      @default(0)
  metadata   String?
  created_at DateTime? @default(now())

  @@unique([type, code], map: "type_code_idx")
}

model ref_compositions {
  id         Int         @id @default(autoincrement())
  code       String?     @unique @db.VarChar(50)
  name       Json
  status     String?     @default("active") @db.VarChar(20)
  created_at DateTime?   @default(now())
  ref_ranks  ref_ranks[]
}

model ref_control_authorities {
  authority_id  Int             @id @default(autoincrement())
  code          String          @unique @db.VarChar(100)
  name          Json
  created_at    DateTime?       @default(now())
  rev_plan_year rev_plan_year[]
}

model ref_control_directions {
  direction_id  Int             @id @default(autoincrement())
  code          String          @unique @db.VarChar(50)
  name          Json
  description   String?
  status        String?         @default("active") @db.VarChar(50)
  created_at    DateTime?       @default(now())
  rev_plan_year rev_plan_year[]
}

model ref_control_types {
  id         Int       @id @default(autoincrement())
  code       String?   @unique @db.VarChar(50)
  name       Json
  status     String?   @default("active") @db.VarChar(20)
  created_at DateTime? @default(now())
}

model ref_decision_statuses {
  id         Int       @id @default(autoincrement())
  code       String?   @unique @db.VarChar(50)
  name       Json
  status     String?   @default("active") @db.VarChar(20)
  created_at DateTime? @default(now())
}

model ref_document_types {
  id         Int       @id @default(autoincrement())
  code       String?   @unique @db.VarChar(50)
  name       Json
  category   String?   @db.VarChar(100)
  status     String?   @default("active") @db.VarChar(20)
  created_at DateTime? @default(now())
}

model ref_education_levels {
  id         Int       @id @default(autoincrement())
  code       String?   @unique @db.VarChar(50)
  name       Json
  status     String?   @default("active") @db.VarChar(20)
  created_at DateTime? @default(now())
}

model ref_financing_sources {
  id         Int       @id @default(autoincrement())
  code       String?   @unique @db.VarChar(50)
  name       Json
  status     String?   @default("active") @db.VarChar(20)
  created_at DateTime? @default(now())
}

model ref_fitness_categories {
  id         Int       @id @default(autoincrement())
  code       String?   @unique @db.VarChar(50)
  name       Json
  status     String?   @default("active") @db.VarChar(20)
  created_at DateTime? @default(now())
}

model ref_genders {
  id                   Int                    @id @default(autoincrement())
  code                 String?                @unique @db.VarChar(50)
  name                 Json
  status               String?                @default("active") @db.VarChar(20)
  created_at           DateTime?              @default(now())
  ref_physical_persons ref_physical_persons[]
}

model ref_inspection_kinds {
  id         Int       @id @default(autoincrement())
  code       String?   @unique @db.VarChar(50)
  name       Json
  status     String?   @default("active") @db.VarChar(20)
  created_at DateTime? @default(now())
}

model ref_inspection_statuses {
  id         Int       @id @default(autoincrement())
  code       String?   @unique @db.VarChar(50)
  name       Json
  status     String?   @default("active") @db.VarChar(20)
  created_at DateTime? @default(now())
}

model ref_inspection_types {
  id            Int             @id @default(autoincrement())
  code          String?         @unique @db.VarChar(50)
  name          Json
  status        String?         @default("active") @db.VarChar(20)
  created_at    DateTime?       @default(now())
  rev_plan_year rev_plan_year[]
}

model ref_military_districts {
  district_id Int         @id @default(autoincrement())
  code        String      @unique @db.VarChar(50)
  name        Json
  short_name  Json?
  area_id     Int?
  status      String?     @default("active") @db.VarChar(50)
  created_at  DateTime?   @default(now())
  ref_areas   ref_areas?  @relation(fields: [area_id], references: [id])
  ref_units   ref_units[]
}

model ref_nationalities {
  id                   Int                    @id @default(autoincrement())
  code                 String?                @unique @db.VarChar(50)
  name                 Json
  status               String?                @default("active") @db.VarChar(20)
  created_at           DateTime?              @default(now())
  ref_physical_persons ref_physical_persons[]
}

model ref_physical_persons {
  id                Int                @id @default(autoincrement())
  pinfl             String             @unique @db.VarChar(14)
  passport_series   String?            @db.VarChar(10)
  passport_number   String?            @db.VarChar(20)
  last_name         String             @db.VarChar(100)
  first_name        String             @db.VarChar(100)
  middle_name       String?            @db.VarChar(100)
  birth_date        DateTime?          @db.Date
  gender_id         Int?
  nationality_id    Int?
  region_id         Int?
  district_id       Int?
  address           String?            @db.VarChar(500)
  photo             String?            @db.VarChar(500)
  contact_phone     String?            @db.VarChar(50)
  email             String?            @db.VarChar(255)
  passport_issued_by String?           @db.VarChar(255)
  passport_expiry_date DateTime?       @db.Date
  birth_place       String?            @db.VarChar(255)
  actual_address    String?            @db.VarChar(500)
  biography         String?            @db.Text
  created_at        DateTime?          @default(now())
  updated_at        DateTime?          @default(now())
  personnel         personnel[]
  ref_areas         ref_areas?         @relation(fields: [district_id], references: [id])
  ref_genders       ref_genders?       @relation(fields: [gender_id], references: [id])
  ref_nationalities ref_nationalities? @relation(fields: [nationality_id], references: [id])
  ref_regions       ref_regions?       @relation(fields: [region_id], references: [id])
}

model ref_positions {
  id         Int         @id
  code       String?     @unique @db.VarChar(50)
  status     String?     @default("active") @db.VarChar(20)
  created_at DateTime?   @default(now())
  name       Json
  personnel  personnel[]
}

model ref_ranks {
  rank_id          Int               @id @default(autoincrement())
  name             Json
  category         String?           @db.VarChar(50)
  level            Int?
  composition_id   Int?
  type             String?           @db.VarChar(20)
  created_at       DateTime?         @default(now())
  personnel        personnel[]
  ref_compositions ref_compositions? @relation(fields: [composition_id], references: [id])
}

model ref_regions {
  id                   Int                    @id @default(autoincrement())
  code                 String?                @unique @db.VarChar(50)
  name                 Json
  type                 String?                @db.VarChar(50)
  status               String?                @default("active") @db.VarChar(20)
  created_at           DateTime?              @default(now())
  ref_areas            ref_areas[]
  ref_physical_persons ref_physical_persons[]
}

model ref_security_clearances {
  id         Int       @id @default(autoincrement())
  code       String?   @unique @db.VarChar(50)
  name       Json
  status     String?   @default("active") @db.VarChar(20)
  created_at DateTime? @default(now())
}

model ref_specializations {
  id         Int         @id @default(autoincrement())
  code       String?     @unique @db.VarChar(50)
  name       Json
  status     String?     @default("active") @db.VarChar(20)
  created_at DateTime?   @default(now())
  ref_units  ref_units[]
}

model ref_statuses {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(50)
  name        Json
  category    String?  @db.VarChar(50)
  description String?
  created_at  DateTime @default(now())
}

model ref_subdivision_names {
  id         Int       @id @default(autoincrement())
  code       String?   @unique @db.VarChar(50)
  name       Json
  status     String?   @default("active") @db.VarChar(20)
  created_at DateTime? @default(now())
}

model ref_supply_departments {
  id         Int       @id @default(autoincrement())
  code       String    @unique @db.VarChar(50)
  name       Json
  short_name Json?
  status     String?   @default("active") @db.VarChar(20)
  created_at DateTime? @default(now())
}

model ref_territory_types {
  id          Int      @id @default(autoincrement())
  code        String   @unique @db.VarChar(50)
  name        Json
  description String?
  status      String   @default("active") @db.VarChar(20)
  created_at  DateTime @default(now())
}

model ref_tmc_types {
  id         Int       @id @default(autoincrement())
  code       String?   @unique @db.VarChar(50)
  name       Json
  status     String?   @default("active") @db.VarChar(20)
  created_at DateTime? @default(now())
}

model ref_unit_types {
  id         Int         @id @default(autoincrement())
  code       String?     @unique @db.VarChar(50)
  name       Json
  status     String?     @default("active") @db.VarChar(20)
  created_at DateTime?   @default(now())
  ref_units  ref_units[]
}

model ref_units {
  unit_id                Int                     @id @default(autoincrement())
  name                   Json
  unit_code              String?                 @unique @db.VarChar(50)
  commander_name         String?                 @db.VarChar(255)
  commander_rank         String?                 @db.VarChar(100)
  unit_type_id           Int?
  specialization_id      Int?
  is_active              Boolean?                @default(true)
  created_at             DateTime?               @default(now())
  military_district_id   Int?
  area_id                Int?
  audits                 audits[]
  findings               findings[]
  inspector_rotations    inspector_rotations[]
  orders                 orders[]
  personnel              personnel[]
  ref_areas              ref_areas?              @relation(fields: [area_id], references: [id])
  ref_military_districts ref_military_districts? @relation(fields: [military_district_id], references: [district_id])
  ref_specializations    ref_specializations?    @relation(fields: [specialization_id], references: [id])
  ref_unit_types         ref_unit_types?         @relation(fields: [unit_type_id], references: [id])
  rev_plan_year          rev_plan_year[]
  unplanned_audits       unplanned_audits[]
  violations             violations[]
}

model ref_violation_reasons {
  id         Int       @id @default(autoincrement())
  code       String?   @unique @db.VarChar(50)
  name       Json
  status     String?   @default("active") @db.VarChar(20)
  created_at DateTime? @default(now())
}

model ref_violation_severities {
  id         Int       @id @default(autoincrement())
  code       String?   @unique @db.VarChar(50)
  name       Json
  status     String?   @default("active") @db.VarChar(20)
  created_at DateTime? @default(now())
}

model ref_violation_statuses {
  id         Int       @id @default(autoincrement())
  code       String?   @unique @db.VarChar(50)
  name       Json
  status     String?   @default("active") @db.VarChar(20)
  created_at DateTime? @default(now())
}

model ref_violations {
  viol_type_id Int       @id @default(autoincrement())
  name         Json
  code         String?   @unique @db.VarChar(50)
  category     String?   @db.VarChar(100)
  severity     String?   @db.VarChar(50)
  description  String?
  legal_basis  String?
  created_at   DateTime? @default(now())
}

model ref_vus_list {
  id         Int         @id
  code       String?     @unique @db.VarChar(50)
  status     String?     @default("active") @db.VarChar(20)
  created_at DateTime?   @default(now())
  name       Json
  personnel  personnel[]
}

model regulatory_documents {
  id         Int      @id @default(autoincrement())
  num        String   @unique @db.VarChar(50)
  type       String   @db.VarChar(50)
  name       String   @db.VarChar(500)
  date       DateTime @db.Date
  direction  String?  @db.VarChar(100)
  status     String   @default("active") @db.VarChar(50)
  content    String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  tags       String[]
  version    Int      @default(1)
}

model rev_plan_year {
  plan_id                                   Int                      @id @default(autoincrement())
  year                                      Int
  plan_number                               String?                  @db.VarChar(50)
  start_date                                DateTime                 @db.Date
  end_date                                  DateTime                 @db.Date
  unit_id                                   Int?
  responsible_id                            Int?
  status                                    String?                  @default("draft") @db.VarChar(50)
  description                               String?
  created_at                                DateTime?                @default(now())
  updated_at                                DateTime?                @default(now())
  approval_date                             DateTime?                @db.Date
  approved_by_id                            Int?
  completed_count                           Int?                     @default(0)
  period_type                               String                   @default("annual") @db.VarChar(50)
  planned_count                             Int?                     @default(0)
  incoming_number                           String?                  @db.VarChar(50)
  incoming_date                             DateTime?                @db.Date
  objects_total                             Int?                     @default(0)
  objects_fs                                Int?                     @default(0)
  objects_os                                Int?                     @default(0)
  expense_classification                    String?                  @db.VarChar(50)
  supply_department                         String?                  @db.VarChar(50)
  subordinate_units_on_allowance            Json?
  period_covered_end                        DateTime?                @db.Date
  period_covered_start                      DateTime?                @db.Date
  control_authority_id                      Int?
  inspection_direction_id                   Int?
  inspection_type_id                        Int?
  briefings                                 briefings[]
  orders                                    orders[]
  plan_change_log                           plan_change_log[]
  prescriptions                             prescriptions[]
  quarterly_plans                           quarterly_plans[]
  users_rev_plan_year_approved_by_idTousers users?                   @relation("rev_plan_year_approved_by_idTousers", fields: [approved_by_id], references: [user_id])
  ref_control_authorities                   ref_control_authorities? @relation(fields: [control_authority_id], references: [authority_id])
  ref_control_directions                    ref_control_directions?  @relation(fields: [inspection_direction_id], references: [direction_id])
  ref_inspection_types                      ref_inspection_types?    @relation(fields: [inspection_type_id], references: [id])
  users_rev_plan_year_responsible_idTousers users?                   @relation("rev_plan_year_responsible_idTousers", fields: [responsible_id], references: [user_id])
  ref_units                                 ref_units?               @relation(fields: [unit_id], references: [unit_id])
}

model ui_translations {
  id          String   @id
  key         String   @unique
  name        Json
  description String?
  tags        String[]
  status      String   @default("active")
  created_at  DateTime @default(now())
  updated_at  DateTime
}

model users {
  user_id                                           Int                       @id @default(autoincrement())
  username                                          String                    @unique @db.VarChar(100)
  password_hash                                     String                    @db.VarChar(255)
  fullname                                          String                    @db.VarChar(255)
  rank                                              String?                   @db.VarChar(100)
  position                                          String?                   @db.VarChar(255)
  role                                              String                    @default("inspector") @db.VarChar(50)
  email                                             String?                   @db.VarChar(255)
  phone                                             String?                   @db.VarChar(50)
  unit_id                                           Int?
  is_active                                         Boolean?                  @default(true)
  created_at                                        DateTime?                 @default(now())
  updated_at                                        DateTime?                 @default(now())
  specialization                                    String?                   @db.VarChar(255)
  has_completed_welcome_tour                        Boolean?                  @default(false)
  audit_log                                         audit_log[]
  audits                                            audits[]
  briefings                                         briefings[]
  commission_members                                commission_members[]
  doc_view_logs                                     doc_view_logs[]
  inspector_profiles                                inspector_profiles?
  internal_investigations                           internal_investigations[]
  notifications                                     notifications[]
  orders                                            orders[]
  prescriptions                                     prescriptions[]
  rev_plan_year_rev_plan_year_approved_by_idTousers rev_plan_year[]           @relation("rev_plan_year_approved_by_idTousers")
  rev_plan_year_rev_plan_year_responsible_idTousers rev_plan_year[]           @relation("rev_plan_year_responsible_idTousers")
  unplanned_audits                                  unplanned_audits[]
  user_kpi_scores                                   user_kpi_scores[]
}

model violations {
  id                 Int         @id @default(autoincrement())
  audit_id           Int
  violation_number   String      @db.VarChar(50)
  category           String      @db.VarChar(100)
  description        String
  amount             Decimal?    @db.Decimal(18, 2)
  severity           String      @db.VarChar(50)
  status             String      @db.VarChar(50)
  responsible_person String?     @db.VarChar(255)
  unit_id            Int?
  detected_date      DateTime    @db.Date
  created_at         DateTime?   @default(now())
  decisions          decisions[]
  audits             audits      @relation(fields: [audit_id], references: [id])
  ref_units          ref_units?  @relation(fields: [unit_id], references: [unit_id])
}

model notifications {
  id         Int      @id @default(autoincrement())
  user_id    Int
  title      String   @db.VarChar(255)
  message    String
  type       String   @db.VarChar(50)
  category   String?  @db.VarChar(50)
  link       String?  @db.VarChar(255)
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())
  users      users    @relation(fields: [user_id], references: [user_id])
}

model i18n_keys {
  id          Int           @id @default(autoincrement())
  key         String        @unique @db.VarChar(255)
  module      String?       @db.VarChar(50)
  i18n_values i18n_values[]
}

model i18n_values {
  id        Int       @id @default(autoincrement())
  key_id    Int
  locale    String    @db.VarChar(10)
  value     String
  i18n_keys i18n_keys @relation(fields: [key_id], references: [id])
}

model inspector_profiles {
  id                  Int                   @id @default(autoincrement())
  user_id             Int                   @unique
  specialization      String?               @db.VarChar(255)
  clearance_level     String?               @db.VarChar(50)
  total_audits        Int                   @default(0)
  users               users                 @relation(fields: [user_id], references: [user_id])
  inspector_rotations inspector_rotations[]
}

model inspector_rotations {
  id                 Int                @id @default(autoincrement())
  profile_id         Int
  unit_id            Int
  position           String             @db.VarChar(255)
  start_date         DateTime           @db.Date
  end_date           DateTime?          @db.Date
  order_number       String?            @db.VarChar(100)
  inspector_profiles inspector_profiles @relation(fields: [profile_id], references: [id])
  ref_units          ref_units          @relation(fields: [unit_id], references: [unit_id])
}

model internal_investigations {
  id            Int       @id @default(autoincrement())
  incident_date DateTime  @db.Date
  incident_type String    @db.VarChar(100)
  subject_id    Int
  inspector_id  Int?
  conclusion    String?
  status        String    @default("active")
  created_at    DateTime  @default(now())
  users         users?    @relation(fields: [inspector_id], references: [user_id])
  personnel     personnel @relation(fields: [subject_id], references: [id])
}

model kpi_metrics {
  id              Int               @id @default(autoincrement())
  code            String            @unique @db.VarChar(50)
  name            Json
  weight          Decimal           @db.Decimal(5, 2)
  formula         String?
  user_kpi_scores user_kpi_scores[]
}

model unplanned_audits {
  id              Int       @id @default(autoincrement())
  request_number  String    @unique @db.VarChar(50)
  source_agency   String    @db.VarChar(100)
  description     String?
  unit_id         Int
  assigned_to     Int?
  status          String    @default("pending")
  document_s3_key String?   @db.VarChar(500)
  created_at      DateTime  @default(now())
  users           users?    @relation(fields: [assigned_to], references: [user_id])
  ref_units       ref_units @relation(fields: [unit_id], references: [unit_id])
}

model user_kpi_scores {
  id           Int         @id @default(autoincrement())
  user_id      Int
  metric_id    Int
  score        Decimal     @db.Decimal(10, 2)
  period_start DateTime    @db.Date
  period_end   DateTime    @db.Date
  kpi_metrics  kpi_metrics @relation(fields: [metric_id], references: [id])
  users        users       @relation(fields: [user_id], references: [user_id])
}

model personnel_contracts {
  id               Int       @id @default(autoincrement())
  personnel_id     Int
  series_number    String    @db.VarChar(50)
  start_date       DateTime  @db.Date
  end_date         DateTime  @db.Date
  status           String    @default("active") @db.VarChar(20)
  created_at       DateTime? @default(now())
  personnel        personnel @relation(fields: [personnel_id], references: [id])
}

model personnel_service_history {
  id               Int       @id @default(autoincrement())
  personnel_id     Int
  unit             String    @db.VarChar(255)
  position         String    @db.VarChar(255)
  start_date       DateTime  @db.Date
  end_date         DateTime? @db.Date
  created_at       DateTime? @default(now())
  personnel        personnel @relation(fields: [personnel_id], references: [id])
}
