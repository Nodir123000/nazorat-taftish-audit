# =====================================================
# Переменные окружения — ШАБЛОН (не использовать в production!)
# Скопируйте файл в .env и заполните реальными значениями.
# НЕ коммитьте .env в систему контроля версий!
# =====================================================

# Строка подключения к PostgreSQL
# Формат: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL="postgresql://db_user:REPLACE_WITH_STRONG_PASSWORD@localhost:5432/nazorat_taftish"

# Секрет для подписи сессионных куки (HMAC-SHA256).
# Минимум 32 случайных символа. Генерация:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="REPLACE_WITH_RANDOM_64_CHAR_HEX_STRING"
